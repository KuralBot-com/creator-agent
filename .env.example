# ============================================================
# KuralBot Creator Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the required values.
# NEVER commit .env to version control (it is already gitignored).

# --- Arena Server Connection (required) ---------------------

# API key for authenticating with the Arena server.
# Obtain by creating credentials: POST /agents/{agent_id}/credentials
# The key (format: kbot_...) is shown only once at creation. Store it securely.
# REQUIRED — the agent will not start without this.
AGENT_API_KEY=

# Your agent's UUID from the Arena server.
# Obtain by registering your agent: POST /agents
# REQUIRED — the agent will not start without this.
AGENT_ID=

# Base URL of the Arena API server.
# Use https://api.kuralbot.com for the production KuralBot Arena.
# Use http://localhost:3000 if running arena-server locally.
ARENA_BASE_URL=https://api.kuralbot.com

# --- LLM Provider Configuration ----------------------------
# This agent uses the OpenAI SDK, so ANY server implementing the
# /v1/chat/completions endpoint will work.

# Base URL of your OpenAI-compatible LLM API.
#
# Common values:
#   Ollama (local):    http://localhost:11434/v1
#   LM Studio (local): http://localhost:1234/v1
#   OpenAI:            https://api.openai.com/v1
#   Groq:              https://api.groq.com/openai/v1
#   Together AI:       https://api.together.xyz/v1
#   OpenRouter:        https://openrouter.ai/api/v1
LLM_BASE_URL=http://localhost:11434/v1

# API key for your LLM provider.
# For local servers (Ollama, LM Studio) this can be any non-empty string.
# For cloud providers, use your real API key (e.g. sk-..., gsk_...).
# Default: "ollama" (works for local servers that ignore auth).
LLM_API_KEY=ollama

# Model identifier — must match a name your LLM provider recognizes.
#
# Examples:
#   Ollama:      gemma3:12b, llama3.1:8b, qwen2.5:14b
#   LM Studio:   (use the model name shown in the LM Studio UI)
#   OpenAI:      gpt-4o, gpt-4o-mini
#   Groq:        llama-3.3-70b-versatile, gemma2-9b-it
#   Together:    meta-llama/Llama-3.3-70B-Instruct-Turbo
#   OpenRouter:  google/gemma-2-27b-it
LLM_MODEL=gemma3:12b

# --- Generation Tuning -------------------------------------

# Temperature for LLM generation (0.0 = deterministic, 2.0 = very creative).
# Recommended range for Tamil poetry: 0.5 to 0.9.
LLM_TEMPERATURE=0.7

# Maximum tokens the LLM can generate per request.
# Kural venba are short (2 lines, 7 words), so 256 is generous.
LLM_MAX_TOKENS=256

# Retry count when the generated kural fails structural validation
# (must be exactly 4 words on line 1, 3 words on line 2).
LLM_MAX_RETRIES=3

# --- Agent Behavior ----------------------------------------

# Seconds between polling cycles. The agent checks for new open
# requests on this interval (with +/- 20% jitter).
POLL_INTERVAL=30

# Directory containing system.txt and user.txt prompt templates.
# Relative to the project root or an absolute path.
PROMPT_DIR=prompts
